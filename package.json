{
  "name": "health-ai-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "cache:clear": "rm -rf .expo node_modules/.cache && node -e \"console.log('Expo (.expo) + node_modules/.cache temizlendi. Metro için: npm run start:clear')\"",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "docker:up": "docker compose up -d --build",
    "docker:up:alt-port": "POSTGRES_PUBLISH_PORT=5434 docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f backend postgres pgadmin"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~55.0.5",
    "expo-constants": "^55.0.7",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.13",
    "expo-linking": "^55.0.7",
    "expo-localization": "^55.0.8",
    "expo-notifications": "~55.0.13",
    "expo-router": "^55.0.4",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.14",
    "nativewind": "^4.2.2",
    "react": "19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.5",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.7.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "^55.0.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
