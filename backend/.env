# Host’tan prisma / npm run start:dev: kök .env POSTGRES_PUBLISH_PORT ile aynı host portu
# docker compose backend: DATABASE_URL compose içinde postgres:5432 ile override edilir
DATABASE_URL="postgresql://healthai:healthai@localhost:5434/healthai?schema=public"

POSTGRES_USER=healthai
POSTGRES_PASSWORD=healthai
POSTGRES_DB=healthai

JWT_SECRET=health-ai-app-jwt-secret-change-in-production
JWT_EXPIRATION=7d
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS=

