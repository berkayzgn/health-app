# ── Database ─────────────────────────────────────────────────────────────────
# LOCAL (npm run start:dev): Postgres runs in Docker on host port 5433
DATABASE_URL="postgresql://healthai:CHANGE_ME_STRONG_PASSWORD@localhost:5433/healthai?schema=public"

# Docker-compose overrides DATABASE_URL at runtime using the postgres service hostname.
# The value above is only used when running the backend directly on the host.

POSTGRES_USER=healthai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=healthai

# ── Auth ─────────────────────────────────────────────────────────────────────
# MUST be a long random string in production. Generate with:
#   openssl rand -hex 64
JWT_SECRET=CHANGE_ME_REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRATION=7d

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── CORS (comma-separated list of allowed origins; leave empty to disable CORS) ──
# Example: https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# ── Google Gemini Vision (etiket taraması) ───────────────────────────────────
# https://aistudio.google.com/app/apikey adresinden ücretsiz key al
GEMINI_API_KEY=
# Varsayılan (kod): gemini-3.1-flash-lite — Text-out: 15 RPM, 250K TPM, 500 RPD (free tier tabloda en yüksek RPD).
# Live API “Unlimited” satırları REST generateContent ile değiştirilemez.
# 404 alırsan sırayla dene:
# GEMINI_MODEL=gemini-2.5-flash-lite   # 10 RPM, 20 RPD
# GEMINI_MODEL=gemini-3-flash          # 5 RPM, 20 RPD
# GEMINI_MODEL=gemini-2.5-flash        # 5 RPM, 20 RPD
# Görsel tokenını azaltmak (varsayılan 1024px kenar, kalite 78):
# GEMINI_IMAGE_MAX_EDGE=1024
# GEMINI_JPEG_QUALITY=78
