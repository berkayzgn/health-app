# ── Nest’i Mac’te çalıştırırken (npm run start:dev) ─────────────────────────
# Postgres Docker: host’ta 5433 (yerel PG 5432 ile çakışmasın diye). Prisma/migrate: localhost:5433
DATABASE_URL="postgresql://healthai:healthai@localhost:5433/healthai?schema=public"

JWT_SECRET=health-ai-app-jwt-secret-change-in-production
JWT_EXPIRATION=7d
PORT=3000

# ── docker compose up (backend konteyneri) ───────────────────────────────────
# Aynı dosya env_file ile yüklenir; DATABASE_URL proje kökündeki docker-compose.yml
# içinde postgres servis adıyla override edilir (konteyner içinde localhost olmaz).
