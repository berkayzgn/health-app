# Proje köküne kopyala: cp .env.example .env
# Değiştirdiğinde Metro'yu yeniden başlat: npx expo start -c

# ── Lokal geliştirme (Docker: docker compose up) ─────────────────────────────
# Simülatör: 127.0.0.1 yeterli. USB ile fiziksel iPhone: aynı Wi‑Fi’de Mac’in LAN IP’sini yaz
# (örn. System Settings → Network veya `ipconfig getifaddr en0`).
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000

# docker-compose.yml içindeki ${POSTGRES_PASSWORD} vb. için (zorunlu)
POSTGRES_USER=healthai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=healthai

# pgAdmin (docker-compose): http://localhost:5050 — sunucu eklerken Host=postgres Port=5432
PGADMIN_EMAIL=admin@healthai.local
PGADMIN_PASSWORD=CHANGE_ME

# Fiziksel telefon / tablet: aynı Wi‑Fi’deki makine IP’si
# EXPO_PUBLIC_API_URL=http://192.168.1.10:3000
# Android emülatör:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:3000

# ── Uzak sunucu (production / EAS) ───────────────────────────────────────────
# .env.production veya deploy sonrası: https://api.alanadiniz.com
