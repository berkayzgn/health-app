# Proje köküne kopyala: cp .env.example .env
# Değiştirdiğinde Metro'yu yeniden başlat: npx expo start -c

# ── Production (DigitalOcean Droplet) ────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://165.245.209.17:3000

# ── Local Development ─────────────────────────────────────────────────────────
# iOS simülatör / Android emülatör:
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
#
# Fiziksel telefon (aynı Wi-Fi):
# EXPO_PUBLIC_API_URL=http://<MAC_IP>:3000   # → ipconfig getifaddr en0
#
# Boş bırakılırsa api.ts __DEV__'de otomatik çözer (iOS localhost / Android 10.0.2.2)
