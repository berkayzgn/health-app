# Proje köküne kopyala: cp .env.example .env
#
# Backend varsayılan port: 3000 (docker-compose ve backend/.env PORT ile aynı olmalı).
#
# iOS simülatör / Android emülatör (Mac’te): loopback kullan — eski 192.168.x.x satırı
# güncel değilse bağlantı zaman aşımına düşer.
# EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
#
# Boş bırakılırsa __DEV__ içinde iOS → http://localhost:3000, Android emülatör → http://10.0.2.2:3000
#
# Fiziksel telefon (aynı Wi‑Fi): Mac’in güncel IP’si (ipconfig getifaddr en0)
# EXPO_PUBLIC_API_URL=http://192.168.1.x:3000
#
# Release / EAS build için genelde zorunludur.
